{
  "name": "intent-eval-dashboard",
  "version": "0.1.0-pre",
  "private": true,
  "type": "module",
  "description": "Public reports dashboard for the Intent Eval Platform. Renders eval-set methodology + signed Evidence Bundles at labs.intentsolutions.io.",
  "homepage": "https://labs.intentsolutions.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/jeremylongshore/intent-eval-dashboard.git"
  },
  "license": "Apache-2.0",
  "author": "Jeremy Longshore <jeremy@intentsolutions.io>",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "harness:verify": "audit-harness verify",
    "harness:init": "audit-harness init",
    "generate:results": "node --experimental-strip-types scripts/generate-results.ts site",
    "generate:status": "node --experimental-strip-types scripts/generate-status.ts site",
    "generate:internal": "node --experimental-strip-types scripts/generate-internal.ts site-internal",
    "generate:internal-testing": "node --experimental-strip-types scripts/generate-internal-testing.ts site-internal",
    "generate:retractions": "node --experimental-strip-types scripts/generate-retractions.ts src/retraction/retractions.json site",
    "lint:c3": "node --experimental-strip-types scripts/lint-no-aggregate-pass.ts site",
    "lint:c3:internal": "node --experimental-strip-types scripts/lint-no-aggregate-pass.ts site-internal",
    "lint:uptime": "node --experimental-strip-types scripts/check-uptime-claims.ts site",
    "lint:arm-symmetry": "node --experimental-strip-types scripts/lint-arm-symmetry.ts site/eval-sets/j-rig-bench",
    "check:liveness": "node --experimental-strip-types scripts/check-liveness-alerts.ts",
    "check": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build && pnpm run generate:results && pnpm run generate:status && pnpm run generate:internal && pnpm run generate:internal-testing && pnpm run generate:retractions && pnpm run lint:c3 && pnpm run lint:c3:internal && pnpm run lint:uptime && pnpm run lint:arm-symmetry"
  },
  "dependencies": {
    "@intentsolutions/core": "^0.2.0",
    "@sigstore/bundle": "^4.0.0",
    "@sigstore/verify": "^4.0.0",
    "sigstore": "^5.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@intentsolutions/audit-harness": "^1.1.5",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.19.0",
    "@typescript-eslint/parser": "^8.19.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0",
    "vitest": "^2.1.8"
  }
}
