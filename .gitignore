# --- Node / pnpm ---
node_modules/
.pnpm-store/
.pnpm-debug.log*
pnpm-lock.yaml.*

# --- Build artifacts ---
dist/
.astro/
site/dist/
site/.astro/
# site-internal/ is the TAILNET-ONLY operator output (puxu.9). Its generated
# HTML IS committed (so the VPS checkout has it for the future tailnet-only
# Caddy block) — only build artifacts under it are ignored, mirroring site/.
site-internal/dist/
site-internal/.astro/
.cache/
build/

# --- Live ingest content/snapshot/gate-row stores (local + VPS; like /var/lib) ---
# Verified bundles are content-addressed here by the ingest pass; the rendered
# HTML in site/ + site-internal/ is the committed artifact, not the raw store.
.ingest-store/

# --- Go (cmd/labs-tui/ reserved for v0.2.0+) ---
cmd/labs-tui/bin/
cmd/labs-tui/*.test

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.DS_Store
*.swp
*.swo

# --- Env / secrets (SOPS pattern) ---
.env
.env.local
.env.*.local
*.env
!secrets.example.yaml
!*.env.sops
secrets.prod.sops.yaml.dec
.sops-decrypted/

# --- Audit-harness cache ---
.audit-harness-cache/
.coverage
coverage/

# --- Editor ---
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.iml
.history/

# --- OS ---
Thumbs.db
ehthumbs.db
*~

# --- Local-only scratch (never commit) ---
/tmp-*
/scratch/
